# .env.example — template for sync_vps_docker.py credentials.
# Copy to .env (which is git/docker-ignored) and fill in the real values:
#   copy .env.example .env
# Real environment variables override .env; CLI flags override both.

# Connection target (required):
VPS_HOST=your.vps.host.or.ip
VPS_PORT=22

# Local destination for the mirror (required):
VPS_LOCAL=C:\path\to\local\mirror\home\debian\docker

# SSH user. root lets the sync read root-owned files (TLS keys, ChromaDB store).
VPS_USER=root

# SSH password. Prefer a key (VPS_KEY_FILE) over a password where possible.
VPS_SSH_PASSWORD=

# Optional — private key path (used instead of the password if set):
# VPS_KEY_FILE=C:\Users\you\.ssh\id_ed25519

# Optional override (default is /home/debian/docker):
# VPS_REMOTE=/home/debian/docker

# Extra remote roots OUTSIDE the main --remote tree, mirrored under the same
# local base (e.g. remote /etc -> <base>\etc). Comma-separated, single line.
# Reading most of these needs root (VPS_USER=root). Skip them all at runtime
# with --no-extra-roots; add one-off roots with repeatable --extra-root.
# Canonical set (the comment after each path explains why it is mirrored):
#   /var/spool/cron/crontabs  cert-renewal (root) + crawler (debian) schedules
#   /var/lib/docker/volumes   WordPress DB, Grafana/Prometheus/Alertmanager, ...
#   /var/lib/bind             authoritative bind9 zone files (outside Docker)
#   /etc                      system config incl. legacy /etc/letsencrypt, sshd, ufw, /etc/bind
#   /home/debian              .ssh/.gnupg/.docker/dotfiles (skips .../docker, its own root)
#   /root                     root .ssh/.gnupg/dotfiles
VPS_EXTRA_ROOTS=/var/spool/cron/crontabs,/var/lib/docker/volumes,/var/lib/bind,/etc,/home/debian,/root
